{
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=Tawny;User Id=sa;Password=DevPassw0rd!;TrustServerCertificate=True;Encrypt=False"
  },
  "Tawny": {
    "ApplyMigrationsOnStartup": false,
    "WebUserHmacSecret": "dev-only-not-secret",
    "AgentJwt": {
      "Issuer": "tawny",
      "Audience": "tawny-agents",
      "LifetimeDays": 90,
      "RotateWithinDays": 7,
      "RequireConfiguredSigningKey": false
    },
    "Enrollment": {
      "TokenLifetimeHours": 24
    },
    "Retention": {
      "EventRetentionDays": 30
    },
    "TelemetryBackup": {
      "LocalPath": "backups/telemetry",
      "S3Bucket": "",
      "S3Prefix": "telemetry"
    },
    "Wazuh": {
      "Enabled": false,
      "Host": "",
      "Port": 514,
      "Protocol": "udp",
      "Facility": 16,
      "AppName": "tawny",
      "Hostname": "",
      "MaxMessageBytes": 8192
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}

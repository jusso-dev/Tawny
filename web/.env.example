# Backend API base URL (server-side only)
TAWNY_API_URL=http://localhost:5080
# Externally reachable API URL used in agent install commands.
NEXT_PUBLIC_TAWNY_AGENT_BACKEND_URL=http://localhost:5080

# Shared HMAC secret for signing requests from Next.js to the .NET API.
# Must match Tawny:WebUserHmacSecret in the API config.
TAWNY_WEB_HMAC_SECRET=dev-only-not-secret

# Better Auth
BETTER_AUTH_SECRET=replace-me-with-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# Better Auth database (SQL Server). Reuses the same DB as the API.
DATABASE_URL=sqlserver://localhost:1433;database=Tawny;user=sa;password=DevPassw0rd!;encrypt=false;trustServerCertificate=true

# Optional first-run admin seed. Run `pnpm seed` after migrations.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_NAME=Tawny Admin

# Optional: GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
